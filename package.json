{
  "name": "bagelink-starter",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build --force --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "bun run type-check && bun run lint && bun run format:check",
    "prepare": "simple-git-hooks",
    "gen:client": "bun --bun run node_modules/.bin/bagelink ./src/api"
  },
  "dependencies": {
    "@bagelink/auth": "^1.14.7",
    "@bagelink/sdk": "^1.14.7",
    "@bagelink/vue": "^1.14.7",
    "axios": "^1.17.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.35",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@bagelink/lint-config": "github:bageldb/bagel-lint-config",
    "@sentry/vite-plugin": "^5.3.0",
    "@types/node": "^25.9.2",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "lint-staged": "^17.0.7",
    "npm-run-all2": "^9.0.1",
    "prettier": "^3.8.3",
    "simple-git-hooks": "^2.13.1",
    "typescript": "~6.0.3",
    "vite": "^8.0.16",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.4"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx --bun lint-staged"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,mts,cts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,html,css,scss}": [
      "prettier --write"
    ]
  },
  "prettier": "@bagelink/lint-config/prettier"
}
